# Flask
FLASK_APP=wsgi:app
FLASK_CONFIG=config.DevelopmentConfig
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flask_microservice

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Authentication — comma-separated list of valid API keys
# Leave empty in dev to disable auth (all requests allowed)
API_KEYS=

# CORS — comma-separated allowed origins (* for all)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
